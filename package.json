{
  "name": "postgres-mcp-server",
  "version": "0.2.0",
  "description": "Secure, diagnostic-first MCP server for PostgreSQL",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "postgres-mcp-server": "build/index.js"
  },
  "scripts": {
    "build": "tsc --noEmit && node -e \"require('fs').rmSync('build', { recursive: true, force: true })\" && esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --minify-whitespace --external:pg-native --banner:js=\"import { createRequire as __bundleCreateRequire } from 'node:module'; const require = __bundleCreateRequire(import.meta.url);\" --outfile=build/index.js && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "check": "tsc --noEmit && tsc -p tsconfig.test.json",
    "dev": "tsx src/index.ts",
    "start": "node build/index.js",
    "start:http": "MCP_TRANSPORT=http node build/index.js",
    "start:sse": "MCP_TRANSPORT=http node build/index.js",
    "start:stdio": "MCP_TRANSPORT=stdio node build/index.js",
    "test": "npm run test:unit",
    "test:unit": "node --import tsx --test test/unit/*.test.ts",
    "test:e2e": "node --import tsx --test test/e2e/*.test.ts",
    "test:e2e:podman": "bash scripts/test-e2e-podman.sh",
    "prepack": "npm run build"
  },
  "keywords": [
    "mcp",
    "postgres",
    "server"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shadabshaukat/postgres-mcp-server.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "pg": "^8.13.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "esbuild": "^0.27.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
